{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",          // 💡 Explicitly set these two lines
    "moduleResolution": "NodeNext",  // 💡 Forces TS to look inside local node_modules
    "types": ["node"] 
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "prisma.config.ts"]
}